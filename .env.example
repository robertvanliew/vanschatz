# --- Production / go-live (all optional in practice mode) ---
# Public URL of the deployed site, used in reminder links:
# NEXT_PUBLIC_BASE_URL="https://your-domain.com"
# Email sending (Resend) — real emails send when set:
# RESEND_API_KEY=""
# EMAIL_FROM="Julie & Robert <invites@your-domain.com>"
# SMS sending (Twilio) — real texts send when all three set:
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_FROM_NUMBER=""
# Protects the daily reminder endpoint — REQUIRED in production:
# CRON_SECRET=""
